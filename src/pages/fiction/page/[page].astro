---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';
import EssayCard from '../../../components/EssayCard.astro';
import {
  buildPaginatedPaths,
  createWithBase,
  getPageSlice,
  getTotalPages,
  getPublished
} from '../../../lib/content';
import { getListExcerpt } from '../../../utils/excerpt';
import { PAGE_SIZE_ESSAY } from '../../../../site.config.mjs';

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);

export async function getStaticPaths() {
  const allEntries = await getPublished('fiction', {
    orderBy: (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  });
  const totalPages = getTotalPages(allEntries.length, PAGE_SIZE_ESSAY);
  return buildPaginatedPaths(totalPages);
}

const currentPage = Number(Astro.params.page);
const allEntries = await getPublished('fiction', {
  orderBy: (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
});
const totalPages = getTotalPages(allEntries.length, PAGE_SIZE_ESSAY);
const pageEntries = getPageSlice(allEntries, currentPage, PAGE_SIZE_ESSAY);

const prevHref = currentPage === 2
  ? withBase('/fiction/')
  : withBase(`/fiction/page/${currentPage - 1}/`);
const nextHref = currentPage < totalPages ? withBase(`/fiction/page/${currentPage + 1}/`) : null;
const pageTitle = `原创作品 / Fiction · 第 ${currentPage} 页`;
---

<BaseLayout title={pageTitle} bodyClass="essay-page">
  <div class="page-header page-header--essay page-header--with-search">
    <div class="page-heading">
      <h1 class="page-title">原创作品 / Fiction</h1>
      <span class="page-subtitle">共 {allEntries.length} 篇 · 第 {currentPage} / {totalPages} 页</span>
    </div>
    <div class="page-actions">
      <div class="entry-search" data-entry-search data-index-url={withBase('/fiction/index.json')}>
        <div class="entry-search-panel" data-entry-search-panel aria-hidden="true">
          <input
            data-entry-search-input
            type="search"
            placeholder="搜索：标题 / 摘要 / 标签"
            autocomplete="off"
            aria-label="搜索原创作品"
          />
        </div>
        <button
          class="entry-search-toggle"
          data-entry-search-toggle
          type="button"
          aria-label="搜索原创作品"
          title="搜索"
          aria-expanded="false"
        >
          <Icon name="search" class="icon" />
        </button>
      </div>
    </div>
  </div>
  <div class="entry-status" data-entry-search-status role="status" aria-live="polite"></div>

  <div class="list">
    {pageEntries.map((e) => (
      <EssayCard
        href={withBase(`/fiction/${e.data.slug ?? e.id}/`)}
        slug={e.data.slug ?? e.id}
        title={e.data.title}
        excerpt={getListExcerpt(e)}
        date={e.data.date}
        tag={e.data.tags?.[0]}
        badge={e.data.badge}
      />
    ))}
  </div>

  <nav class="pagination" aria-label="原创作品分页">
    <div class="pagination__inner">
      <a class="pagination__link" rel="prev" href={prevHref}>上一页</a>
      {nextHref ? (
        <a class="pagination__link pagination__link--next" rel="next" href={nextHref}>下一页</a>
      ) : null}
    </div>
  </nav>

  <script>
    import '../../../scripts/entry-search.ts';
  </script>
</BaseLayout>
